DGII_ECF_ENVIRONMENT=testecf
DGII_ECF_CERT_PATH=certificado_dgii/20260501-2020077-KQBYARLQB.p12
OPENSSL_CONF=config/openssl-legacy.cnf
OPENSSL_MODULES=C:\php\extras\ssl
DGII_ECF_CERT_PASSWORD=CAMBIAR_PASSWORD_DEL_CERTIFICADO

# Guard de emision e-CF del modulo de Gastos (E41/E43/E47).
# false (o ausente) = NO se emite a DGII: los gastos auto-emision se guardan como
# PENDIENTE_EMISION sin consumir secuencia. Poner en true SOLO cuando se quiera
# emitir de verdad (probar primero en testecf/certecf, no en produccion ecf).
DGII_ECF_EMISSION_ENABLED=false

# ============================================================================
# Multi-emisor (DB-per-tenant) — ver docs/architecture.md
# ============================================================================
# Activa el ruteo multi-tenant. false (o ausente) = comportamiento de hoy:
# todo va al DB del .env (DB_*). true = auth en master + ruteo por tenant.
# NO poner en true hasta crear gratex_master, migrar Gratex y probar en staging.
MULTI_TENANT_ENABLED=false

# Conexion al master DB (registro de tenants + auth centralizada)
MASTER_DB_HOST=localhost
MASTER_DB_PORT=3306
MASTER_DB_NAME=gratex_master
MASTER_DB_USER=master_user
MASTER_DB_PASS=CAMBIAR

# Clave AES-256 para cifrar credenciales de tenant (64 chars hex = 32 bytes).
# Generar UNA sola vez:  php -r "echo bin2hex(random_bytes(32)).PHP_EOL;"
MASTER_ENCRYPTION_KEY=

# (Opcional) Usuario MySQL con privilegio CREATE DATABASE para onboarding
# (tools/create_tenant.php). Si se omite, usa MASTER_DB_USER/PASS.
ADMIN_DB_USER=
ADMIN_DB_PASS=

# Token que autoriza correr los runners de certificacion por web
# (public/cert_run.php, usado por el wizard public/cert.html). Secreto.
CERT_RUN_TOKEN=CAMBIAR

# Tokens de las herramientas de operaciones bajo public/ (antes hardcodeados en
# el codigo; ahora SIEMPRE del entorno). Sin valor => la herramienta responde 403.
# Usar secretos largos y aleatorios, DISTINTOS entre si:
#   php -r "echo bin2hex(random_bytes(24)).PHP_EOL;"
# IMPORTANTE: el parser NO soporta comentarios en la misma linea (todo lo que va
# despues del '=' es el valor, incluido cualquier '#'). Comentarios en su propia
# linea. NO reutilizar un mismo valor para varios tokens.
# ONBOARD_TOKEN        -> tools/create_tenant.php (alta de tenants)
ONBOARD_TOKEN=CAMBIAR
# CREATE_USER_TOKEN    -> public/create_user.php (alta de usuarios)
CREATE_USER_TOKEN=CAMBIAR
# IMPORT_RECIBIDO_TOKEN -> public/import_recibido.php (import e-CF recibidos)
IMPORT_RECIBIDO_TOKEN=CAMBIAR
# PLANTILLAS_TOKEN     -> public/plantillas.php (branding/plantilla PDF)
PLANTILLAS_TOKEN=CAMBIAR
# READLOG_TOKEN        -> public/readlog.php (debug: lee error_log)
READLOG_TOKEN=CAMBIAR

# Secreto HMAC del token del handshake de autenticacion DGII (semilla->token).
# Sin valor => se usa un secreto EFIMERO aleatorio por proceso (ya no un valor
# committeado). Fijar en produccion para estabilidad entre procesos.
ECF_AUTH_TOKEN_SECRET=CAMBIAR

# ============================================================================
# Roles y permisos (RBAC) — ver docs/modules/roles-permisos.md
# ============================================================================
# Aplicacion de permisos en el PermissionGate (Router). false (o ausente) =
# modo SOMBRA: no bloquea, solo registra en error_log lo que se denegaria
# (para descubrir gaps con trafico real). true = aplica de verdad (403/401).
# Activar SOLO tras sembrar roles (migracion 003) y revisar los logs en sombra.
PERMISSIONS_ENFORCE=false

# Bitacora de auditoria (audit_logs): registra quien hizo que y cuando. true (o
# ausente) = encendido. La escritura es tolerante a fallos (nunca rompe el
# request) y nunca guarda passwords/secrets/tokens en claro. false = la apaga.
AUDIT_LOG_ENABLED=true
